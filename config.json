{
  "name": "Orca Search Module",
  "namespace": "ORCA\\OrcaSearch",
  "description": "A configurable, searchable, and performant, list dashboard",
  "authors": [
    {
      "name": "Chris Kadolph",
      "email": "chris.kadolph@vumc.org",
      "institution": "Vanderbilt University Medical Center"
    },
    {
      "name": "Leila Deering",
      "email": "deering.leila@marshfieldresearch.org",
      "institution": "Marshfield Clinic Research Institute"
    }
  ],
  "framework-version": 15,
  "links": {
    "project": [
      {
        "name": "Orca Search Configuration",
        "icon": "fa-solid fa-gears",
        "url": "config.php",
        "show-header-and-footer": true,
        "restricted": true
      },
      {
        "name": "Orca Search Dashboard",
        "icon": "fa-solid fa-search",
        "url": "search.php",
        "show-header-and-footer": true
      }
    ]
  },
  "auth-ajax-actions": [
    "initialize-config-dashboard",
    "initialize-search-dashboard",
    "search",
    "save-module-config"
  ],
  "project-settings": [
    {
      "key": "replace_add_edit",
      "name": "Replace the Add/Edit Records link with a link to this module's search page?",
      "type": "checkbox",
      "hidden": true
    },
    {
      "key": "search_limit",
      "name": "Limit the search results",
      "type": "text",
      "hidden": true
    },
    {
      "key": "instance_search",
      "name": "Which instances to search through",
      "type": "text",
      "hidden": true
    },
    {
      "key": "include_dag_if_exists",
      "name": "Include DAG in results (only if project uses DAGs)",
      "type": "checkbox",
      "hidden": true
    },
    {
      "key": "empty_search_disabled",
      "name": "Prevent an empty search from yielding results",
      "type": "checkbox",
      "hidden": true
    },
    {
      "key": "record_home_display",
      "name": "Where to position Record Home button in the display fields table (default=Last Column, use None to hide it)",
      "type": "text",
      "hidden": true
    },
    {
      "key": "display_context_enabled",
      "name": "Show the event/instance context of search results",
      "type": "checkbox",
      "hidden": true
    },
    {
      "key": "search_fields",
      "name": "Searchable Fields",
      "type": "sub_settings",
      "repeatable": true,
      "hidden": true,
      "sub_settings": [
        {
          "key": "search_field_name",
          "name": "Searchable Field Name",
          "type": "text",
          "repeatable": false
        },
        {
          "key": "search_field_label",
          "name": "Custom Display Label",
          "type": "text",
          "repeatable": false
        },
        {
          "key": "search_field_name_wildcard",
          "name": "Return Partial Matches?",
          "type": "checkbox",
          "repeatable": false
        }
      ]
    },
    {
      "key": "display_fields",
      "name": "Select the fields for display",
      "type": "sub_settings",
      "repeatable": true,
      "hidden": true,
      "sub_settings": [
        {
          "key": "display_field_name",
          "name": "Field To Display in the Results Table",
          "type": "field-list",
          "repeatable": false
        },
        {
          "key": "display_field_header",
          "name": "Use a custom header in place of the normal Field Label.",
          "type": "text",
          "repeatable": false
        },
        {
          "key": "display_field_sort_on_field",
          "name": "Check if you wish to sort the table on this field.",
          "type": "checkbox",
          "repeatable": false
        },
        {
          "key": "display_field_sort_direction",
          "name": "Sort Direction",
          "type": "text",
          "repeatable": false
        },
        {
          "key": "display_field_sort_priority",
          "name": "The order this sorted field should be applied in. (a number between 1 and the number of columns in the table)",
          "type": "text",
          "repeatable": false
        }
      ]
    }
  ]
}
